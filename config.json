  "alertRules": [
    { "pattern": "zero.?day|0.?day", "boost": 5 },
    { "pattern": "actively.?exploit|active.?exploitation|exploited.?in.?the.?wild", "boost": 5 },
    { "pattern": "emergency.?directive|emergency.?patch", "boost": 5 },
    { "pattern": "ransomware|LockBit|BlackCat|ALPHV|Cl0p|BlackBasta|RansomHub", "boost": 4 },
    { "pattern": "supply.?chain|dependency.?confusion|typosquat|malicious.?package", "boost": 4 },
    { "pattern": "nation.?state|APT\\d+|state.?sponsor", "boost": 4 },
    { "pattern": "breach.?notification|mandatory.?disclos|SEC.?cyber|8-K.*cyber", "boost": 3 },
    { "pattern": "Fortinet|Ivanti|Citrix|Pulse.?Secure|GlobalProtect|edge.?device", "boost": 3 },
    { "pattern": "Okta|Entra|Active.?Directory|SSO|identity.?provider|MFA.?bypass", "boost": 3 },
    { "pattern": "VMware|ESXi|hypervisor", "boost": 3 },
    { "pattern": "ICS|SCADA|operational.?technology|OT.?network", "boost": 3 },
    { "pattern": "agentic|AI.?agent|LLM.?security|model.?context.?protocol|prompt.?injection", "boost": 3 },
    { "pattern": "post.?quantum|PQC|quantum.?comput", "boost": 2 },
    { "pattern": "executive.?order|NIS2|DORA|CIRCIA", "boost": 2 }
  ],

  "analysisSettings": {
    "model": "claude-haiku-4-5",
    "preferredModel": "claude-sonnet-5",
    "maxSignals": 6,
    "maxPatterns": 3,
    "maxConvergence": 2,
    "maxTokens": 16000,
    "freshnessHours": 48,
    "continuityDepth": 5,
    "refreshMinutes": 10,
    "maxArticleExtractions": 10,
    "maxCVEEnrichments": 8,
    "headlineArchiveDays": 14,
    "generationTimeoutSec": 300,
    "thinkingEffort": "medium",
    "horizonWeights": {
      "horizon1": 0.45,
      "horizon2": 0.4,
      "horizon3": 0.15
    },
    "scoring": {
      "recencyHalfLifeHours": 30,
      "axisWeights": {
        "recency": 0.22,
        "corroboration": 0.18,
        "exploitation": 0.28,
        "severity": 0.16,
        "relevance": 0.16
      }
    },
    "debugScoring": false,
    "webhook": {
      "url": "",
      "format": "slack",
      "events": "alerts"
    }
  }

# ── AI briefing (optional — the Wall and Wire work without it) ──
# Anthropic API key enables the daily AI-written landscape briefing.
# (ANTHROPIC_API_KEY_PRIMARY is accepted as an alias, for parity with
# ANTHROPIC_API_KEY_SECONDARY below — either name works.)
ANTHROPIC_API_KEY=

# Optional fallback key, rotated to automatically on auth failure.
ANTHROPIC_API_KEY_SECONDARY=

# ── Enrichment (optional) ──
# NVD API key raises the CVE-lookup rate limit (5 -> 50 requests / 30s).
# Free: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Optional feed-reader identity sent to RSS/advisory hosts. The default names
# BlueTeam.News and links to blueteam.news; set this to add an operator contact URL
# if your organization or a feed provider requires one.
BLUETEAM_USER_AGENT=

# ── Server ──
# Port to listen on.
PORT=3000

# Bind address. Default 127.0.0.1 (localhost only) — the intended deployment.
# Run BlueTeam.News on the machine that drives the display (a mini-PC or Pi behind
# the TV, or your host on a second monitor) and open /wall on 127.0.0.1.
HOST=127.0.0.1

# Canonical origin used in RSS/JSON feed metadata and links sent with completed
# Briefing webhooks. Must be an absolute http(s) origin with no path, query,
# fragment, or credentials. Leave blank for request-derived local feed URLs and
# a safe http://localhost:PORT fallback in webhook links.
PUBLIC_BASE_URL=

# Bearer-token auth for all /api/* routes. The server refuses to bind a
# non-loopback HOST without it — a fail-closed guard against accidental exposure.
API_SECRET=

# Allowed CORS origin (defaults to same-origin).
CORS_ORIGIN=

# Behind a reverse proxy (nginx, Caddy, Cloudflare)? Set a hop count (e.g. "1")
# or a subnet/"loopback" so Express trusts its X-Forwarded-* headers for
# rate-limiting, client IP, and emitted feed URLs. Leave unset otherwise —
# without it those headers are ignored, so a direct client can't spoof them.
# PUBLIC_BASE_URL takes precedence over forwarded headers in emitted feed URLs.
TRUST_PROXY=

# Allow the keyless /embed iframe route even when API_SECRET is enabled.
# Leave disabled unless the embedding origin and reverse proxy are locked down.
ENABLE_EMBED=

# Set to "production" for JSON logs + HSTS.
NODE_ENV=
